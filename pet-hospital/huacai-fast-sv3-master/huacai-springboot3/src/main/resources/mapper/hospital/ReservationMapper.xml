<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.huacai.hospital.mapper.ReservationMapper">
    
    <resultMap type="Reservation" id="ReservationResult">
        <result property="reservationId"    column="reservation_id"    />
        <result property="type"    column="type"    />
        <result property="status"    column="status"    />
        <result property="petName"    column="pet_name"    />
        <result property="petBread"    column="pet_bread"    />
        <result property="petAge"    column="pet_age"    />
        <result property="symptom"    column="symptom"    />
        <result property="date"    column="date"    />
        <result property="time"    column="time"    />
        <result property="doctorId"    column="doctor_id"    />
        <result property="vaccineId"    column="vaccine_id"    />
        <result property="userId"    column="user_id"    />
        <result property="createTime"    column="create_time"    />
        <result property="name"    column="name"    />
        <result property="title"    column="title"    />
        <result property="specialty"    column="specialty"    />
        <result property="photo"    column="photo"    />
        <result property="vaccineName"    column="vaccineName"    />
        <result property="userName"    column="user_name"    />
    </resultMap>

    <sql id="selectReservationVo">
        select reservation_id, type, status, pet_name, pet_bread, pet_age, symptom, date, time, doctor_id, vaccine_id, user_id, create_time from reservation
    </sql>

    <select id="selectReservationList" parameterType="Reservation" resultMap="ReservationResult">
        select r.reservation_id, r.type, r.status, r.pet_name, r.pet_bread, r.pet_age, r.symptom,
        r.date, r.time, r.doctor_id, r.vaccine_id, r.user_id, r.create_time,
        d.name, d.title, d.specialty, d.photo,
        v.name as vaccineName,
        u.user_name
        from reservation r
        left join doctor d on r.doctor_id = d.doctor_id
        left join vaccine v on r.vaccine_id = v.vaccine_id
        left join sys_user u on r.user_id = u.user_id
        <where>
            <if test="type != null  and type != ''"> and r.type = #{type}</if>
            <if test="status != null  and status != ''"> and r.status = #{status}</if>
            <if test="petName != null  and petName != ''"> and r.pet_name like concat('%', #{petName}, '%')</if>
            <if test="doctorId != null  and doctorId != ''"> and r.doctor_id = #{doctorId}</if>
            <if test="vaccineId != null  and vaccineId != ''"> and r.vaccine_id = #{vaccineId}</if>
            <if test="date != null "> and r.date = #{date}</if>
            <if test="userId != null "> and r.user_id = #{userId}</if>
            <if test="name != null  and name != ''"> and d.name like concat('%', #{name}, '%')</if>
            <if test="vaccineName != null  and vaccineName != ''"> and v.name like concat('%', #{vaccineName}, '%')</if>
            <if test="userName != null  and userName != ''"> and u.user_name like concat('%', #{userName}, '%')</if>
        </where>
    </select>

    <select id="selectReservationByReservationId" parameterType="String" resultMap="ReservationResult">
        select r.reservation_id, r.type, r.status, r.pet_name, r.pet_bread, r.pet_age, r.symptom,
               r.date, r.time, r.doctor_id, r.vaccine_id, r.user_id, r.create_time,
               d.name, d.title, d.specialty, d.photo,
               v.name as vaccineName,
               u.user_name
        from reservation r
                 left join doctor d on r.doctor_id = d.doctor_id
                 left join vaccine v on r.vaccine_id = v.vaccine_id
                 left join sys_user u on r.user_id = u.user_id
        where reservation_id = #{reservationId}
    </select>

    <!--预约状态统计-->
    <select id="selectCategoryChart" resultType="com.huacai.hospital.domain.vo.PieVO">
        select status as name, count(reservation_id) as value
        from reservation
        group by status
    </select>

    <insert id="insertReservation" parameterType="Reservation">
        insert into reservation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="reservationId != null">reservation_id,</if>
            <if test="type != null and type != ''">type,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="petName != null and petName != ''">pet_name,</if>
            <if test="petBread != null and petBread != ''">pet_bread,</if>
            <if test="petAge != null">pet_age,</if>
            <if test="symptom != null and symptom != ''">symptom,</if>
            <if test="date != null and date != ''">date,</if>
            <if test="time != null and time != ''">time,</if>
            <if test="doctorId != null">doctor_id,</if>
            <if test="vaccineId != null">vaccine_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="reservationId != null">#{reservationId},</if>
            <if test="type != null and type != ''">#{type},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="petName != null and petName != ''">#{petName},</if>
            <if test="petBread != null and petBread != ''">#{petBread},</if>
            <if test="petAge != null">#{petAge},</if>
            <if test="symptom != null and symptom != ''">#{symptom},</if>
            <if test="date != null and date != ''">#{date},</if>
            <if test="time != null and time != ''">#{time},</if>
            <if test="doctorId != null">#{doctorId},</if>
            <if test="vaccineId != null">#{vaccineId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateReservation" parameterType="Reservation">
        update reservation
        <trim prefix="SET" suffixOverrides=",">
            <if test="type != null and type != ''">type = #{type},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="petName != null and petName != ''">pet_name = #{petName},</if>
            <if test="petBread != null and petBread != ''">pet_bread = #{petBread},</if>
            <if test="petAge != null">pet_age = #{petAge},</if>
            <if test="symptom != null and symptom != ''">symptom = #{symptom},</if>
            <if test="date != null and date != ''">date = #{date},</if>
            <if test="time != null and time != ''">time = #{time},</if>
            <if test="doctorId != null">doctor_id = #{doctorId},</if>
            <if test="vaccineId != null">vaccine_id = #{vaccineId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where reservation_id = #{reservationId}
    </update>

    <delete id="deleteReservationByReservationId" parameterType="String">
        delete from reservation where reservation_id = #{reservationId}
    </delete>

    <delete id="deleteReservationByReservationIds" parameterType="String">
        delete from reservation where reservation_id in 
        <foreach item="reservationId" collection="array" open="(" separator="," close=")">
            #{reservationId}
        </foreach>
    </delete>
</mapper>